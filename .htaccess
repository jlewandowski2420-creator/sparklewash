# ═══════════════════════════════════════════
# SparkleWash — .htaccess (AKTYWNY — Cloud86 LiteSpeed)
# ═══════════════════════════════════════════

# ── Enable Rewrite Engine ──
RewriteEngine On

# ── Force HTTPS ──
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]

# ── Force non-www ──
RewriteCond %{HTTP_HOST} ^www\.(.*)$ [NC]
RewriteRule ^(.*)$ https://%1/$1 [R=301,L]

# ── GZIP Compression ──
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json application/xml
</IfModule>

# ── Cache-Control Headers ──
<IfModule mod_expires.c>
  ExpiresActive On
  # Images — 1 year
  ExpiresByType image/jpg "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  # CSS & JS — 1 week
  ExpiresByType text/css "access plus 1 week"
  ExpiresByType application/javascript "access plus 1 week"
  # HTML — 1 day
  ExpiresByType text/html "access plus 1 day"
</IfModule>

# ── Security Headers ──
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "DENY"
  Header always set X-XSS-Protection "1; mode=block"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=()"
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
  # Cache-Control for CSS (cache busting via query string)
  Header set Cache-Control "public, max-age=86400" "expr=%{CONTENT_TYPE} =~ m#text/css#"
  # Content Security Policy
  Header always set Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self' https://fonts.googleapis.com 'unsafe-inline'; font-src https://fonts.gstatic.com; connect-src 'self' https://formspree.io; img-src 'self' data:; base-uri 'self'; form-action 'self' https://formspree.io"
</IfModule>

# ── Block access to hidden files ──
<FilesMatch "^\.">
  Require all denied
</FilesMatch>

# ── Block access to .git ──
RewriteRule ^\.git - [F,L]

# ── Custom 404 page ──
# ErrorDocument 404 /404.html
